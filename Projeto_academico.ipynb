        "outputId": "4787e3bc-4f00-460a-8a47-877d2c829658"
      },
      "source": [
        "# Criar faixas etárias\n",
        "def categorizar_idade(idade):\n",
        "    if idade < 12:\n",
        "        return '0-11 (Criança)'\n",
        "    elif 12 <= idade <= 17:\n",
        "        return '12-17 (Adolescente)'\n",
        "    elif 18 <= idade <= 24:\n",
        "        return '18-24 (Jovem Adulto)'\n",
        "    elif 25 <= idade <= 39:\n",
        "        return '25-39 (Adulto)'\n",
        "    elif 40 <= idade <= 59:\n",
        "        return '40-59 (Meia-idade)'\n",
        "    else:\n",
        "        return '60+ (Idoso)'\n",
        "\n",
        "df_desaparecidos['Faixa_Etaria'] = df_desaparecidos['Idade_Vitima'].apply(categorizar_idade)\n",
        "\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.countplot(data=df_desaparecidos, x='Faixa_Etaria', palette='coolwarm', order=sorted(df_desaparecidos['Faixa_Etaria'].unique()))\n",
        "plt.title('Distribuição de Desaparecimentos por Faixa Etária')\n",
        "plt.xlabel('Faixa Etária')\n",
        "plt.ylabel('Número de Casos')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.grid(axis='y', alpha=0.75)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "execution_count": 18,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": [
            "/tmp/ipykernel_15549/712676799.py:19: FutureWarning: \n",
