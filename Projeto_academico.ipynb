        "# Resumo estatístico das idades (média, mínimo, máximo)\n",
        "print(\"--- Resumo das Idades ---\")\n",
        "display(df_desaparecidos['Idade_Vitima'].describe())\n",
        "\n",
        "# Média de idade separada por gênero\n",
        "print(\"\\n--- Média de Idade por Gênero ---\")\n",
        "display(df_desaparecidos.groupby('Genero')['Idade_Vitima'].mean().round(1))"
      ],
