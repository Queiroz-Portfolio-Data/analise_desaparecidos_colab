      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import random\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "# Garantir que os dados gerados sejam sempre os mesmos toda vez que rodar\n",
        "np.random.seed(42)\n",
        "random.seed(42)\n",
        "\n",
        "# Atualizado para 400 registros conforme você pediu!\n",
        "qtd_registros = 400\n",
        "\n",
        "# Listas de opções para preencher a base de dados\n",
        "estados_br = ['SP', 'RJ', 'MG', 'BA', 'CE', 'PR', 'PE', 'GO', 'AM', 'SC', 'RS', 'PA', 'DF']\n",
        "generos = ['Feminino', 'Masculino']\n",
        "status_caso = ['Ainda Desaparecido', 'Localizado (Bem)', 'Resgatado de Exploração', 'Óbito']\n",
        "suspeita_trafico = ['Sim', 'Não', 'Em Investigação']\n",
        "\n",
        "# Gerando datas aleatórias nos últimos 3 anos para dar mais variedade\n",
        "data_inicial = datetime(2021, 1, 1)\n",
        "datas_registro = [data_inicial + timedelta(days=random.randint(0, 1095)) for _ in range(qtd_registros)]\n",
        "\n",
        "# Construindo o Dicionário de Dados\n",
        "dados = {\n",
        "    'ID_Ocorrencia': range(1001, 1001 + qtd_registros),\n",
        "    'Data_Registro': datas_registro,\n",
        "    'Idade_Vitima': np.random.randint(12, 65, qtd_registros), # Idades entre 12 e 65 anos\n",
        "    'Genero': np.random.choice(generos, qtd_registros, p=[0.60, 0.40]), # Maioria feminino\n",
        "    'Estado_Ocorrencia': np.random.choice(estados_br, qtd_registros),\n",
        "    'Status_Atual': np.random.choice(status_caso, qtd_registros, p=[0.35, 0.40, 0.15, 0.10]),\n",
        "    'Suspeita_Trafico_Humano': np.random.choice(suspeita_trafico, qtd_registros, p=[0.25, 0.50, 0.25])\n",
        "}\n",
        "\n",
        "# Criando o DataFrame (Tabela) no Pandas\n",
        "df_desaparecidos = pd.DataFrame(dados)\n",
        "\n",
        "# Ordenando pela data\n",
        "df_desaparecidos = df_desaparecidos.sort_values(by='Data_Registro').reset_index(drop=True)\n",
        "\n",
        "# Salvando a base de dados em um arquivo CSV dentro do seu Colab\n",
        "df_desaparecidos.to_csv('base_desaparecidos_400.csv', index=False, sep=';')\n",
        "\n",
        "# Mostrando as informações da base e as 10 primeiras linhas\n",
        "print(f\"Base de dados criada com sucesso com {len(df_desaparecidos)} registros!\")\n",
        "print(\"-\" * 400)\n",
        "display(df_desaparecidos.head(400))"
      ]
    },
