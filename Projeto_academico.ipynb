    {
      "cell_type": "markdown",
      "metadata": {
        "id": "348a4259"
      },
      "source": [
        "### Análise Detalhada de Casos com Suspeita de Tráfico Humano 'Em Investigação'"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 882
        },
        "id": "02646ec7",
        "outputId": "19e51fb4-7a40-40d0-fa86-57a18ca3909f"
      },
      "source": [
        "# Filtrar casos com 'Suspeita_Trafico_Humano' como 'Em Investigação'\n",
        "df_investigacao = df_desaparecidos[df_desaparecidos['Suspeita_Trafico_Humano'] == 'Em Investigação'].copy()\n",
        "\n",
        "# Classificar por faixa etária e gênero\n",
        "def classificar_vitima(row):\n",
        "    if row['Idade_Vitima'] < 18:\n",
        "        return 'Criança'\n",
        "    elif row['Genero'] == 'Masculino':\n",
        "        return 'Homem'\n",
        "    else:\n",
        "        return 'Mulher'\n",
        "\n",
        "df_investigacao['Tipo_Vitima'] = df_investigacao.apply(classificar_vitima, axis=1)\n",
        "\n",
        "# Contar os tipos de vítimas\n",
        "contagem_tipos_vitima = df_investigacao['Tipo_Vitima'].value_counts()\n",
        "\n",
        "print(\"Casos com 'Suspeita_Trafico_Humano' em 'Em Investigação' por Tipo de Vítima:\")\n",
        "display(contagem_tipos_vitima)\n",
        "\n",
        "# Visualização\n",
        "plt.figure(figsize=(8, 6))\n",
        "sns.barplot(x=contagem_tipos_vitima.index, y=contagem_tipos_vitima.values, palette='plasma')\n",
        "plt.title('Distribuição de Vítimas em Casos de Tráfico Humano (Em Investigação)')\n",
        "plt.xlabel('Tipo de Vítima')\n",
        "plt.ylabel('Número de Casos')\n",
        "plt.grid(axis='y', alpha=0.75)\n",
        "plt.show()"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Casos com 'Suspeita_Trafico_Humano' em 'Em Investigação' por Tipo de Vítima:\n"
